{
  "name": "mybricks-taro-webview",
  "displayName": "VibeTaroUI",
  "description": "Vibe prototype、Vibe design、Vibe Coding",
  "icon": "images/icon.png",
  "version": "0.0.48",
  "publisher": "mybricks",
  "scripts": {
    "inspect": "npx @modelcontextprotocol/inspector --config ./mcp.json",
    "compile": "npm run build:extension && npm run build:webview",
    "watch": "npm run watch:extension & npm run watch:webview",
    "build:extension": "tsc -p ./",
    "watch:extension": "tsc -watch -p ./",
    "build:webview": "vite build",
    "watch:webview": "vite build --watch",
    "dev": "npm run watch",
    "build:vsix": "npm run build:webview && vsce package --out ./unpackage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mybricks/mybricks-ide-as-vscode-plugin.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri",
    "onCustomEditor:mybricks.taro.editor"
  ],
  "main": "./extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "mybricks.taro.editor",
        "displayName": "VibeTaro Editor",
        "selector": [
          {
            "filenamePattern": "*.tui"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "mybricks.taro.openIDE",
        "title": "Open MyBricks IDE",
        "icon": "asserts/icon.svg"
      },
      {
        "command": "mybricks.taro.init",
        "title": "初始化 MyBricks 环境"
      },
      {
        "command": "mybricks.taro.openFile",
        "title": "用 MyBricks 打开"
      },
      {
        "command": "mybricks.taro.newUIFile",
        "title": "新建 .tui 文件"
      },
      {
        "command": "mybricks.taro.enableMCPService",
        "title": "开启 MCP 服务"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mybricks.taro.openFile",
          "when": "resourceExtname == .tui",
          "group": "navigation"
        },
        {
          "command": "mybricks.taro.newUIFile",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mybricks-taro-sidebar",
          "title": "VibeTaroUI",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "mybricks-taro-sidebar": [
        {
          "type": "webview",
          "id": "mybricks.taro.ide",
          "name": "FILES"
        }
      ]
    },
    "configuration": {
      "title": "MyBricks",
      "properties": {
        "mybricksTaro.mcp.enabled": {
          "type": "boolean",
          "default": false,
          "description": "是否开启 MCP 服务"
        },
        "mybricksTaro.ai.token": {
          "type": "string",
          "default": "",
          "description": "AI 请求凭证（Token），用于设计器内 AI 能力。请在 MyBricks 平台获取 Token 后填写。"
        },
        "mybricksTaro.preferredFileExtension": {
          "type": "string",
          "default": ".tui",
          "enum": [
            ".tui"
          ],
          "description": "新建/另存为时默认使用 .tui 后缀。"
        }
      }
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5"
  },
  "devDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@ant-design/icons": "^6.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.60.0",
    "@vitejs/plugin-react": "^4.2.1",
    "antd": "^6.2.3",
    "fs-extra": "^11.3.3",
    "less": "^4.6.4",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "@tarojs/components": "^4.2.0",
    "@tarojs/plugin-framework-react": "^4.2.0",
    "@tarojs/plugin-platform-h5": "^4.2.0",
    "@tarojs/taro": "^4.2.0",
    "@tarojs/taro-h5": "^4.2.0",
    "@mybricks/tarojs-components": "^0.0.5",
    "@mybricks/tarojs-plugin-framework-react": "^0.0.3",
    "@mybricks/tarojs-router": "^0.0.3",
    "@mybricks/tarojs-runtime": "^0.0.2",
    "@mybricks/tarojs-taro-h5": "^0.0.4",
    "@nutui/icons-react-taro": "^3.0.2-cpp.3.beta.9"
  },
  "volta": {
    "node": "20.18.0"
  }
}
